---
interface Props {
  t: any;
}
const { t } = Astro.props;
const d = t.domains;
---
<section id="domains" class="section">
  <div class="container">
    <p class="section-label">{d.label}</p>
    <h2 class="section-title">{d.title}</h2>
    <p class="section-lede">{d.lede}</p>

    <div class="grid">
      {d.cards.map((card: any, i: number) => (
        <article class="card domain">
          <div class="domain-head">
            <span class="domain-index num">0{i + 1}</span>
            <span class="chip">{card.tag}</span>
          </div>
          <h3 class="domain-name">{card.name}</h3>
          <ul class="domain-points">
            {card.points.map((p: string) => (
              <li>{p}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  .domain {
    padding: 26px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .domain:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }
  .domain-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .domain-index {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink-faint);
  }
  .domain-name {
    font-size: 1.35rem;
    margin-top: 16px;
  }
  .domain-points {
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .domain-points li {
    position: relative;
    padding-left: 24px;
    color: var(--ink-soft);
    font-size: 0.98rem;
    line-height: 1.45;
  }
  .domain-points li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--flame);
    opacity: 0.85;
  }
  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
