---
import { APP_URL, API_URL, CONTACT_EMAIL } from "../lib/config";
interface Props {
  t: any;
  lang: "fr" | "en";
}
const { t, lang } = Astro.props;
const pr = t.pricing;
const selfHostHref = lang === "fr" ? "/docs/self-hosting/" : "/en/docs/self-hosting/";

function ctaHref(kind: string) {
  return kind === "contact" ? `mailto:${CONTACT_EMAIL}` : APP_URL;
}
---
<section id="pricing" class="section">
  <div class="container">
    <div class="pricing-head">
      <p class="section-label">{pr.label}</p>
      <h2 class="section-title">{pr.title}</h2>
      <p class="section-lede">{pr.lede}</p>
      <div
        class="interval-toggle"
        data-pricing-endpoint={`${API_URL}/api/v1/pricing`}
        data-lang={lang}
        data-per-month={pr.per.month}
        data-per-year={pr.per.year}
        hidden
      >
        <button type="button" class="on" data-interval="month">{pr.toggle.month}</button>
        <button type="button" data-interval="year">{pr.toggle.year}</button>
        <span class="chip annual">{pr.annualNote}</span>
      </div>
    </div>

    <div class="tiers">
      {pr.cards.map((card: any) => (
        <article class={`tier card ${card.featured ? "featured" : ""}`} data-slug={card.slug}>
          <div class="tier-name">{card.name}</div>
          <div class="tier-price">
            {/* content values are the SEO / no-JS fallback; the live Stripe
                amount from /api/v1/pricing overwrites them on load */}
            <span class="price num" data-price>{card.price}</span>
            <span class="period" data-period>{card.period}</span>
          </div>
          <div class="tier-quota num">{card.quota}</div>
          <ul class="tier-features">
            {card.features.map((f: string) => (
              <li>{f}</li>
            ))}
          </ul>
          <a
            href={ctaHref(card.kind)}
            class={`btn ${card.featured ? "btn-primary" : "btn-ghost"} tier-cta`}
            rel={card.kind === "contact" ? undefined : "noopener"}
          >{card.cta}</a>
        </article>
      ))}
    </div>

    <p class="self-host-line">
      {pr.selfHostLead} <a href={selfHostHref}>{pr.selfHostLink}</a>
    </p>
  </div>
</section>

<script>
  // Live pricing: read the real Stripe amounts from the public endpoint and
  // fill each card, so nothing is hardcoded. The static content stays as a
  // graceful fallback (no-JS / API down). A monthly/annual toggle re-renders.
  const toggle = document.querySelector<HTMLElement>(".interval-toggle");
  if (toggle) {
    const endpoint = toggle.dataset.pricingEndpoint!;
    const lang = toggle.dataset.lang || "en";
    const per = { month: toggle.dataset.perMonth || "", year: toggle.dataset.perYear || "" };
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".tier[data-slug]"));
    type Plan = {
      slug: string;
      amount_cents: number | null;
      amount_cents_annual: number | null;
      currency: string | null;
    };

    const money = (cents: number, currency: string) =>
      new Intl.NumberFormat(lang, {
        style: "currency",
        currency: (currency || "eur").toUpperCase(),
        maximumFractionDigits: cents % 100 === 0 ? 0 : 2,
      }).format(cents / 100);

    fetch(endpoint)
      .then((r) => (r.ok ? r.json() : Promise.reject(r.status)))
      .then((plans: Plan[]) => {
        const bySlug = new Map(plans.map((p) => [p.slug, p]));
        const hasAnnual = plans.some((p) => p.amount_cents_annual != null);
        if (hasAnnual) toggle.hidden = false;

        const render = (interval: "month" | "year") => {
          for (const card of cards) {
            const plan = bySlug.get(card.dataset.slug || "");
            const cents = plan
              ? interval === "year"
                ? plan.amount_cents_annual
                : plan.amount_cents
              : null;
            if (plan && cents != null) {
              const priceEl = card.querySelector<HTMLElement>("[data-price]");
              const periodEl = card.querySelector<HTMLElement>("[data-period]");
              if (priceEl) priceEl.textContent = money(cents, plan.currency || "eur");
              if (periodEl) periodEl.textContent = per[interval];
            }
          }
        };

        render("month");
        toggle.querySelectorAll<HTMLButtonElement>("button[data-interval]").forEach((btn) => {
          btn.addEventListener("click", () => {
            toggle
              .querySelectorAll("button[data-interval]")
              .forEach((b) => b.classList.remove("on"));
            btn.classList.add("on");
            render(btn.dataset.interval as "month" | "year");
          });
        });
      })
      .catch(() => {
        /* keep the static fallback prices */
      });
  }
</script>

<style>
  .pricing-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pricing-head .section-title,
  .pricing-head .section-lede {
    margin-left: auto;
    margin-right: auto;
  }
  .interval-toggle {
    margin-top: 22px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .interval-toggle button {
    border: 1px solid var(--line);
    background: var(--bg);
    color: var(--ink-soft);
    border-radius: 8px;
    padding: 6px 14px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .interval-toggle button.on {
    background: var(--flame);
    border-color: var(--flame);
    color: #fff;
  }
  .interval-toggle .chip.annual {
    margin-left: 6px;
  }
  .tiers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-top: 48px;
    align-items: stretch;
  }
  .tier {
    padding: 26px 22px;
    display: flex;
    flex-direction: column;
  }
  .tier.featured {
    border-color: var(--flame);
    box-shadow: 0 0 0 1px var(--flame), var(--shadow-card);
  }
  .tier-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
  }
  .tier-price {
    margin-top: 14px;
    display: flex;
    align-items: baseline;
    gap: 7px;
  }
  .price {
    font-size: 1.9rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .period {
    font-size: 0.85rem;
    color: var(--ink-faint);
  }
  .tier-quota {
    margin-top: 8px;
    font-size: 0.82rem;
    color: var(--flame-strong);
    font-weight: 500;
  }
  .tier-features {
    list-style: none;
    padding: 0;
    margin: 22px 0 26px;
    display: flex;
    flex-direction: column;
    gap: 11px;
    flex: 1;
  }
  .tier-features li {
    position: relative;
    padding-left: 22px;
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }
  .tier-features li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 7px;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--flame);
    opacity: 0.8;
  }
  .tier-cta {
    width: 100%;
  }
  .self-host-line {
    text-align: center;
    margin-top: 32px;
    color: var(--ink-soft);
    font-size: 1rem;
  }
  .self-host-line a {
    font-weight: 600;
  }
  @media (max-width: 900px) {
    .tiers {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .tiers {
      grid-template-columns: 1fr;
    }
  }
</style>
