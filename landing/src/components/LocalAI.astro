---
interface Props {
  t: any;
}
const { t } = Astro.props;
const ai = t.ai;
---
<section id="ai" class="section">
  <div class="container ai-grid">
    <div class="ai-intro">
      <p class="section-label">{ai.label}</p>
      <h2 class="section-title">{ai.title}</h2>
      <p class="section-lede">{ai.lede}</p>
      <div class="ai-badge">
        <span class="ai-lock" aria-hidden="true">
          <svg viewBox="0 0 20 20" width="15" height="15" fill="none">
            <rect x="4" y="9" width="12" height="8" rx="2" stroke="currentColor" stroke-width="1.6" />
            <path d="M7 9V6.5a3 3 0 0 1 6 0V9" stroke="currentColor" stroke-width="1.6" />
          </svg>
        </span>
        <span class="num">SPT Models · on-prem GPU</span>
      </div>
    </div>
    <div class="ai-points">
      {ai.points.map((pt: any, i: number) => (
        <div class="ai-point">
          <span class="ai-num num">0{i + 1}</span>
          <div>
            <h3>{pt.title}</h3>
            <p>{pt.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ai-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 56px;
    align-items: start;
  }
  .ai-intro {
    position: sticky;
    top: 96px;
  }
  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: 28px;
    padding: 8px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-soft);
  }
  .ai-lock {
    color: var(--flame);
    display: grid;
    place-items: center;
  }
  .ai-points {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ai-point {
    display: flex;
    gap: 18px;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    align-items: flex-start;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .ai-point:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-soft);
  }
  .ai-num {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--flame);
    padding-top: 2px;
  }
  .ai-point h3 {
    font-size: 1.1rem;
  }
  .ai-point p {
    margin-top: 6px;
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.5;
  }
  @media (max-width: 860px) {
    .ai-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .ai-intro {
      position: static;
    }
  }
</style>
