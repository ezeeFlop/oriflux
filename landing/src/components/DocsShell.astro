---
// Two-column docs chrome (sidebar + article), rendered inside Base's slot.
// The guide list and its order come from content (t.docs.guides) so both the
// sidebar and the index share one source of truth and stay translatable.
interface Props {
  t: any;
  lang: "fr" | "en";
  current?: string;
}
const { t, lang, current } = Astro.props;
const docsBase = lang === "fr" ? "/docs/" : "/en/docs/";
const guides = t.docs.guides;
---
<div class="container docs-wrap">
  <aside class="docs-side">
    <a href={docsBase} class={`docs-home ${!current ? "active" : ""}`}>{t.docs.home}</a>
    <nav class="docs-nav" aria-label={t.docs.onThisPage}>
      <p class="docs-nav-label">{t.docs.onThisPage}</p>
      {guides.map((g: any) => (
        <a
          href={`${docsBase}${g.slug}/`}
          class={`docs-link ${current === g.slug ? "active" : ""}`}
          aria-current={current === g.slug ? "page" : undefined}
        >{g.label}</a>
      ))}
    </nav>
  </aside>
  <article class="docs-article">
    <slot />
  </article>
</div>

<style>
  .docs-wrap {
    display: grid;
    grid-template-columns: 250px minmax(0, 1fr);
    gap: 56px;
    padding-top: 48px;
    padding-bottom: 96px;
    align-items: start;
  }
  .docs-side {
    position: sticky;
    top: 88px;
  }
  .docs-home {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    padding: 8px 12px;
    border-radius: var(--radius-sm);
  }
  .docs-home.active,
  .docs-home:hover {
    color: var(--flame);
    background: var(--flame-soft);
  }
  .docs-nav {
    margin-top: 18px;
    border-top: 1px solid var(--line);
    padding-top: 18px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .docs-nav-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding: 0 12px;
    margin-bottom: 8px;
  }
  .docs-link {
    display: block;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.35;
    border-left: 2px solid transparent;
  }
  .docs-link:hover {
    color: var(--ink);
    background: var(--surface-2);
  }
  .docs-link.active {
    color: var(--flame);
    font-weight: 600;
    background: var(--flame-soft);
    border-left-color: var(--flame);
  }
  .docs-article {
    min-width: 0;
    max-width: 76ch;
  }
  @media (max-width: 860px) {
    .docs-wrap {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .docs-side {
      position: static;
      border-bottom: 1px solid var(--line);
      padding-bottom: 20px;
    }
    .docs-nav {
      flex-flow: row wrap;
    }
    .docs-nav-label {
      width: 100%;
    }
  }
</style>
