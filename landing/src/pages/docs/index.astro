---
import Base from "../../layouts/Base.astro";
import DocsShell from "../../components/DocsShell.astro";
import fr from "../../content/fr.json";
import "../../styles/docs.css";

const t = fr;
const lang = "fr" as const;
const guides = t.docs.guides;
---
<Base
  t={t}
  lang={lang}
  path="/docs/"
  altPath="/en/docs/"
  title={`${t.docs.title} — Oriflux`}
  description={t.docs.lede}
>
  <DocsShell t={t} lang={lang}>
    <div class="docs-index">
      <h1>{t.docs.title}</h1>
      <p class="docs-lede">{t.docs.lede}</p>
      <div class="guide-list">
        {guides.map((g: any) => (
          <a href={`/docs/${g.slug}/`} class="guide-card">
            <h2>{g.label}</h2>
            <p>{g.desc}</p>
            <span class="guide-slug num">/docs/{g.slug}/</span>
          </a>
        ))}
      </div>
    </div>
  </DocsShell>
</Base>

<style>
  .docs-lede {
    margin-top: 12px;
    font-size: 1.1rem;
    color: var(--ink-soft);
  }
  .guide-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 32px;
  }
  .guide-card {
    display: block;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .guide-card:hover {
    border-color: var(--flame);
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }
  .guide-card h2 {
    font-size: 1.15rem;
    color: var(--ink);
  }
  .guide-card p {
    margin-top: 8px;
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .guide-slug {
    display: inline-block;
    margin-top: 14px;
    font-size: 0.76rem;
    color: var(--ink-faint);
  }
  @media (max-width: 720px) {
    .guide-list {
      grid-template-columns: 1fr;
    }
  }
</style>
