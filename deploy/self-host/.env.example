# Oriflux self-host configuration — copy to .env and fill the secrets.
# Full guide: https://oriflux.sponge-theory.dev/docs/self-hosting

# ── Required secrets (generate strong random values) ────────────────────────
# e.g.  openssl rand -hex 32
CLICKHOUSE_PASSWORD=
POSTGRES_PASSWORD=
ORIFLUX_JWT_SECRET=

# ── Dashboard sign-in (Google OAuth) ────────────────────────────────────────
# The dashboard authenticates with Google Sign-In. Create a free OAuth client
# (https://console.cloud.google.com/apis/credentials, type "Web application",
# authorized JavaScript origin = your dashboard URL) and paste its client id.
ORIFLUX_GOOGLE_CLIENT_ID=

# ── First organization (printed by `python -m oriflux.bootstrap`) ───────────
ORIFLUX_BOOTSTRAP_ORG_SLUG=my-org
ORIFLUX_BOOTSTRAP_ORG_NAME=My Organization
# The Google account that owns the dashboard:
ORIFLUX_BOOTSTRAP_OWNER_EMAIL=
# Comma-separated "slug:Display Name" projects to create:
ORIFLUX_BOOTSTRAP_PROJECTS=my-product:My Product
# Where your dashboard will be reachable (shown at the end of bootstrap):
ORIFLUX_BOOTSTRAP_APP_URL=http://localhost:8080

# ── Optional ────────────────────────────────────────────────────────────────
# Fernet key to enable revenue connectors (Stripe/Lemon Squeezy secrets at rest):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ORIFLUX_FERNET_KEY=
# GeoIP provider: dbip (default, keyless) or maxmind (needs MAXMIND_LICENSE_KEY)
ORIFLUX_GEOIP_PROVIDER=dbip
MAXMIND_LICENSE_KEY=
# Host ports:
ORIFLUX_WEB_PORT=8080
ORIFLUX_INGEST_PORT=8100
# Image source — override to run your own builds:
ORIFLUX_REGISTRY=ghcr.io/ezeeflop
ORIFLUX_TAG=latest
